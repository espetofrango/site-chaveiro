</footer>

<style>
  .site-footer {
    background: #050508;
    margin-top: 100px;
  }

  /* CTA Final */
  .cta-final {
    padding-bottom: 80px;
    margin-top: -60px;
    position: relative;
    z-index: 10;
  }

  .cta-card {
    background: linear-gradient(135deg, var(--color-secondary) 0%, var(--color-accent) 100%);
    border-radius: var(--radius);
    padding: 60px;
    text-align: center;
    box-shadow: 0 20px 50px rgba(0,0,0,0.5);
  }

  .cta-content h2 {
    font-size: clamp(32px, 5vw, 48px);
    margin-bottom: 20px;
    color: #fff;
  }

  .cta-content p {
    font-size: 18px;
    color: rgba(255,255,255,0.8);
    margin-bottom: 40px;
    max-width: 600px;
    margin-inline: auto;
  }

  .contact-form {
    display: flex;
    gap: 12px;
    max-width: 500px;
    margin: 0 auto 32px;
  }

  .contact-form input {
    flex: 1;
    padding: 16px 24px;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(255,255,255,0.2);
    background: rgba(255,255,255,0.1);
    color: #fff;
    font-size: 16px;
    backdrop-filter: blur(10px);
  }

  .contact-form button {
    background: var(--color-primary);
    color: var(--color-bg);
    border: none;
    padding: 16px 24px;
    border-radius: var(--radius-sm);
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .contact-form button:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(255, 215, 0, 0.4);
  }

  .success-msg {
    color: #22c55e;
    font-weight: 700;
    margin-bottom: 20px;
  }

  .guarantees {
    display: flex;
    justify-content: center;
    gap: 24px;
    flex-wrap: wrap;
    font-size: 14px;
    font-weight: 600;
    color: rgba(255,255,255,0.7);
  }

  /* Footer Main */
  .footer-main {
    padding-top: 80px;
    border-top: 1px solid var(--color-border);
  }

  .grid-footer {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.5fr;
    gap: 60px;
    margin-bottom: 80px;
  }

  .logo-link {
    display: block;
    margin-bottom: 20px;
  }

  .footer-logo {
    height: 60px;
    width: auto;
  }

  .tagline {
    color: var(--color-text-muted);
    font-size: 14px;
    line-height: 1.6;
    margin-bottom: 24px;
  }

  .social-links {
    display: flex;
    gap: 16px;
  }

  .social-links a {
    width: 40px;
    height: 40px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
  }

  .social-links a:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
    transform: translateY(-3px);
  }

  .social-links svg {
    width: 18px;
    height: 18px;
  }

  .footer-links h4 {
    font-size: 16px;
    margin-bottom: 24px;
    color: #fff;
  }

  .footer-links ul {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-links a {
    color: var(--color-text-muted);
    font-size: 14px;
  }

  .footer-links a:hover {
    color: var(--color-primary);
  }

  .footer-links p {
    color: var(--color-text-muted);
    font-size: 14px;
  }

  .footer-bottom {
    padding: 32px 0;
    border-top: 1px solid var(--color-border);
  }

  .footer-bottom .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-bottom p {
    color: var(--color-text-muted);
    font-size: 12px;
  }

  .legal-links {
    display: flex;
    gap: 24px;
  }

  .legal-links a {
    color: var(--color-text-muted);
    font-size: 12px;
  }

  @media (max-width: 1024px) {
    .grid-footer {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }
    
    .footer-brand {
      grid-column: span 2;
    }
  }

  @media (max-width: 768px) {
    .cta-card {
      padding: 40px 20px;
    }
    
    .contact-form {
      flex-direction: column;
    }
    
    .grid-footer {
      grid-template-columns: 1fr;
    }
    
    .footer-brand {
      grid-column: span 1;
    }

    .footer-bottom .container {
      flex-direction: column;
      gap: 16px;
      text-align: center;
    }
  }
</style>

<script>
  const btn = document.getElementById('cta-btn');
  const input = document.getElementById('phone-input') as HTMLInputElement;
  const success = document.getElementById('success-msg');

  btn?.addEventListener('click', () => {
    if (input.value.length > 8) {
      success!.style.display = 'block';
      input.value = '';
      setTimeout(() => {
        success!.style.display = 'none';
      }, 5000);
    } else {
      alert('Por favor, insira um telefone válido.');
    }
  });
</script>
