---
const steps = [
  {
    number: "01",
    title: "Chame agora",
    description: "Entre em contato via WhatsApp ou telefone. Informe o seu problema e envie sua localização para agilizarmos o socorro.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>`
  },
  {
    number: "02",
    title: "Orçamento rápido",
    description: "Nossos especialistas avaliam a situação e passam o valor com total transparência, sem taxas escondidas.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>`
  },
  {
    number: "03",
    title: "Serviço concluído",
    description: "O técnico chega em minutos no bairro de Anchieta e região, resolvendo o problema com técnica e ferramentas modernas.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>`
  }
];
---

<section class="how-it-works section-padding">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">Simples e Rápido</span>
      <h2>Como funciona o atendimento?</h2>
    </div>

    <div class="steps-container">
      {steps.map((step, index) => (
        <div class="step-item reveal" style={`transition-delay: ${index * 0.2}s`}>
          <div class="step-visual">
            <span class="step-number">{step.number}</span>
            <div class="icon-box" set:html={step.icon} />
            {index < steps.length - 1 && <div class="connector-line"></div>}
          </div>
          <div class="step-content">
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .how-it-works {
    background: var(--color-bg);
    position: relative;
  }

  .section-header {
    text-align: center;
    margin-bottom: 80px;
  }

  .steps-container {
    display: flex;
    justify-content: space-between;
    gap: 40px;
  }

  .step-item {
    flex: 1;
    text-align: center;
    position: relative;
  }

  .step-visual {
    position: relative;
    width: 100%;
    display: flex;
    justify-content: center;
    margin-bottom: 32px;
  }

  .step-number {
    position: absolute;
    top: -20px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-display);
    font-size: 80px;
    font-weight: 800;
    color: var(--color-primary);
    opacity: 0.1;
    z-index: 0;
  }

  .icon-box {
    width: 80px;
    height: 80px;
    background: var(--color-secondary);
    color: var(--color-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
    border: 1px solid var(--color-border);
    box-shadow: 0 0 20px rgba(0,0,0,0.3);
  }

  .icon-box :global(svg) {
    width: 32px;
    height: 32px;
  }

  .connector-line {
    position: absolute;
    top: 50%;
    left: calc(50% + 50px);
    width: calc(100% - 100px);
    height: 2px;
    background: linear-gradient(90deg, var(--color-primary) 0%, transparent 100%);
    opacity: 0.3;
    z-index: 0;
  }

  .step-content h3 {
    font-size: 24px;
    margin-bottom: 16px;
    color: var(--color-primary);
  }

  .step-content p {
    color: var(--color-text-muted);
    line-height: 1.6;
    max-width: 280px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .steps-container {
      flex-direction: column;
      gap: 60px;
    }

    .connector-line {
      display: none;
    }

    .step-visual {
      margin-bottom: 16px;
    }

    .step-number {
      font-size: 60px;
      top: -10px;
    }
  }
</style>
