---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf()
).slice(0, 3);

// Placeholders se houver menos de 3 posts
const placeholdersNeeded = Math.max(0, 3 - posts.length);
const placeholders = Array(placeholdersNeeded).fill(null);
---

<section class="latest-posts section-padding">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">Nosso Blog</span>
      <h2>Últimas atualizações e dicas.</h2>
      <p>Acompanhe nossos artigos sobre segurança e serviços em Anchieta.</p>
    </div>

    <div class="posts-grid">
      {posts.map((post, index) => (
        <a href={`/blog/${post.slug}`} class="post-card reveal" style={`transition-delay: ${index * 0.1}s`}>
          <div class="card-content">
            <span class="category">{post.data.category}</span>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <span class="read-more">Ler mais →</span>
          </div>
        </a>
      ))}

      {placeholders.map((_, index) => (
        <div class="post-card placeholder reveal" style={`transition-delay: ${(posts.length + index) * 0.1}s`}>
          <div class="card-content">
            <div class="placeholder-icon">✦</div>
            <h3>Novo post em breve...</h3>
            <p>Estamos preparando mais conteúdos exclusivos sobre segurança e cutelaria para você.</p>
          </div>
        </div>
      ))}
    </div>

    <div class="view-all reveal">
      <a href="/blog" class="btn btn-secondary">Ver todo o blog</a>
    </div>
  </div>
</section>

<style>
  .latest-posts {
    background: #050508;
  }

  .section-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 60px;
  }

  .post-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    padding: 32px;
    border-radius: var(--radius);
    transition: all 0.4s ease;
    display: flex;
    flex-direction: column;
    text-decoration: none;
  }

  .post-card:not(.placeholder):hover {
    transform: translateY(-8px);
    border-color: var(--color-primary);
    box-shadow: 0 10px 30px rgba(255, 215, 0, 0.1);
  }

  .post-card.placeholder {
    border-style: dashed;
    opacity: 0.6;
  }

  .placeholder-icon {
    font-size: 32px;
    color: var(--color-primary);
    margin-bottom: 20px;
    opacity: 0.5;
  }

  .category {
    color: var(--color-primary);
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 16px;
    display: block;
  }

  h3 {
    font-size: 20px;
    margin-bottom: 12px;
    color: #fff;
    line-height: 1.4;
  }

  p {
    color: var(--color-text-muted);
    font-size: 15px;
    line-height: 1.6;
    margin-bottom: 24px;
    flex-grow: 1;
  }

  .read-more {
    font-weight: 700;
    color: var(--color-primary);
    font-size: 14px;
  }

  .view-all {
    text-align: center;
  }

  .btn-secondary {
    display: inline-block;
    padding: 14px 32px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: #fff;
    font-weight: 700;
    transition: all 0.3s ease;
  }

  .btn-secondary:hover {
    background: var(--color-bg-card);
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  @media (max-width: 1024px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
