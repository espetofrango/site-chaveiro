---
const testimonials = [
  {
    name: "Ana Rodrigues",
    role: "Moradora de Anchieta",
    content: "Fiquei trancada do lado de fora do meu apartamento às 22h e o Chaveiro Anchieta chegou em menos de 15 minutos. Abriram a porta sem estragar nada. Recomendo demais!",
    initials: "AR",
    color: "#0073CF"
  },
  {
    name: "Bruno Carvalho",
    role: "Comerciante",
    content: "Melhor chaveiro da região. Precisava de uma cópia de chave codificada para o meu carro e eles resolveram na hora com um preço muito justo. Nota 10 pelo conhecimento técnico!",
    initials: "BC",
    color: "#FFD700",
    featured: true
  },
  {
    name: "Camila Torres",
    role: "Lojista na Pavuna",
    content: "Contratei para instalar travas de segurança na minha loja e o serviço foi impecável. Demonstraram total domínio sobre os sistemas de segurança. Com certeza usarei novamente.",
    initials: "CT",
    color: "#E30613"
  }
];
---

<section class="testimonials section-padding">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">Depoimentos</span>
      <h2>O que dizem nossos clientes.</h2>
    </div>

    <div class="testimonials-grid">
      {testimonials.map((t, index) => (
        <div class={`testimonial-card reveal ${t.featured ? 'featured' : ''}`} style={`transition-delay: ${index * 0.1}s`}>
          <div class="stars">★★★★★</div>
          <p class="content">"{t.content}"</p>
          <div class="author">
            <div class="avatar" style={`background: ${t.color}`}>
              {t.initials}
            </div>
            <div class="info">
              <strong>{t.name}</strong>
              <span>{t.role}</span>
            </div>
          </div>
          <span class="quote-icon">"</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials {
    background: radial-gradient(circle at center, #0f0f1a 0%, var(--color-bg) 100%);
  }

  .section-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    align-items: center;
  }

  .testimonial-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--color-border);
    padding: 40px;
    border-radius: var(--radius);
    backdrop-filter: blur(12px);
    position: relative;
    overflow: hidden;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .testimonial-card.featured {
    transform: scale(1.05);
    background: rgba(255, 215, 0, 0.05);
    border-color: var(--color-primary);
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    z-index: 2;
  }

  .quote-icon {
    position: absolute;
    top: 20px;
    right: 30px;
    font-size: 120px;
    font-family: serif;
    color: var(--color-primary);
    opacity: 0.1;
    line-height: 1;
    pointer-events: none;
  }

  .stars {
    color: var(--color-primary);
    margin-bottom: 20px;
    letter-spacing: 2px;
  }

  .content {
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: 32px;
    position: relative;
    z-index: 1;
  }

  .author {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    color: var(--color-bg);
    font-size: 14px;
  }

  .info {
    display: flex;
    flex-direction: column;
  }

  .info strong {
    font-size: 16px;
    color: var(--color-text);
  }

  .info span {
    font-size: 13px;
    color: var(--color-text-muted);
  }

  @media (max-width: 1024px) {
    .testimonial-card.featured {
      transform: scale(1);
    }
    
    .testimonials-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }
</style>
