---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Chaveiro Anchieta RJ - Sua segurança em boas mãos, 24 horas por dia em Anchieta e região. Atendimento ultra-rápido residencial, comercial e automotivo." } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Syne:wght@400;700;800&display=swap" rel="stylesheet">
    
    <title>{title}</title>
    
    <!-- SEO Tags -->
    <link rel="canonical" href="https://www.chaveiroanchieta.com.br/" />
    <meta name="robots" content="index, follow" />
    <meta name="keywords" content="chaveiro 24h anchieta, chaveiro automotivo anchieta, chaveiro residencial anchieta, abertura de portas rj, chaves codificadas anchieta, segurança residencial rj, afiação de tesouras anchieta, amolar facas rj, cutelaria profissional" />
    
    <!-- Open Graph / SEO -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.chaveiroanchieta.com.br/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og-image.jpg" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content="Chaveiro Anchieta RJ" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-image.jpg" />

    <!-- Geo Tags -->
    <meta name="geo.region" content="BR-RJ" />
    <meta name="geo.placename" content="Rio de Janeiro" />
    <meta name="geo.position" content="-22.8234;-43.3921" />
    <meta name="ICBM" content="-22.8234, -43.3921" />

    <!-- Schema.org LocalBusiness -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Chaveiro Anchieta RJ",
        "image": "https://www.chaveiroanchieta.com.br/logo.png",
        "@id": "https://www.chaveiroanchieta.com.br",
        "url": "https://www.chaveiroanchieta.com.br",
        "telephone": "+5521970780881",
        "priceRange": "$$",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Rua Cipriano Barata, 11",
          "addressLocality": "Parque Anchieta",
          "addressRegion": "RJ",
          "postalCode": "21645-510",
          "addressCountry": "BR"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": -22.8234,
          "longitude": -43.3921
        },
