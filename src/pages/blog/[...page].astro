---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';

export async function getStaticPaths({ paginate }) {
  const posts = (await getCollection('blog')).sort(
    (a, b) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf()
  );
  
  // Gera páginas com 10 posts cada
  return paginate(posts, { pageSize: 10 });
}

const { page } = Astro.props;
---

<Layout title="Blog - Chaveiro Anchieta RJ | Dicas de Segurança e Serviços">
  <Navbar />
  <main class="blog-index">
    <header class="blog-header">
      <div class="container">
        <span class="eyebrow">Dicas e Conteúdo</span>
        <h1>Blog do Chaveiro Anchieta</h1>
        <p>Informações relevantes sobre segurança, chaves e serviços na Zona Norte do Rio.</p>
      </div>
    </header>

    <section class="posts-list section-padding">
      <div class="container">
        <div class="posts-grid">
          {page.data.map(post => (
            <a href={`/blog/${post.slug}`} class="post-card reveal">
              <span class="category">{post.data.category}</span>
              <span class="date">{post.data.publishDate}</span>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              <span class="read-more">Ler artigo completo →</span>
            </a>
          ))}
        </div>

        {page.lastPage > 1 && (
          <div class="pagination">
            {page.url.prev ? (
              <a href={page.url.prev} class="btn-page">← Anterior</a>
            ) : (
              <span class="btn-page disabled">← Anterior</span>
            )}
            
            <span class="page-info">Página {page.currentPage} de {page.lastPage}</span>
            
            {page.url.next ? (
              <a href={page.url.next} class="btn-page">Próxima →</a>
            ) : (
              <span class="btn-page disabled">Próxima →</span>
            )}
          </div>
        )}
      </div>
    </section>
  </main>
</Layout>

<style>
  .blog-index {
    padding-top: 100px;
    background: var(--color-bg);
  }

  .blog-header {
    padding: 60px 0 40px;
    text-align: center;
  }

  .eyebrow {
    color: var(--color-primary);
    text-transform: uppercase;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 2px;
    display: block;
    margin-bottom: 16px;
  }

  h1 {
    font-size: clamp(40px, 6vw, 64px);
    margin-bottom: 20px;
    color: #fff;
  }

  .blog-header p {
    color: var(--color-text-muted);
    font-size: 18px;
    max-width: 600px;
    margin: 0 auto;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
  }

  .post-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    padding: 40px;
    border-radius: var(--radius);
    transition: all 0.4s ease;
    display: flex;
    flex-direction: column;
    text-decoration: none;
  }

  .post-card:hover {
    transform: translateY(-8px);
    border-color: var(--color-primary);
    background: rgba(255, 215, 0, 0.02);
  }

  .category {
    color: var(--color-primary);
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 12px;
    display: block;
  }

  .date {
    color: var(--color-text-muted);
    font-size: 13px;
    margin-bottom: 16px;
  }

  h2 {
    font-size: 24px;
    margin-bottom: 16px;
    color: #fff;
    line-height: 1.3;
  }

  .post-card p {
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 24px;
    flex-grow: 1;
  }

  .read-more {
    font-weight: 700;
    color: var(--color-primary);
    font-size: 14px;
  }

  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: 60px;
  }

  .btn-page {
    padding: 10px 24px;
    border: 1px solid var(--color-primary);
    color: var(--color-primary);
    text-decoration: none;
    border-radius: var(--radius-sm);
    font-weight: 700;
    transition: all 0.3s ease;
  }

  .btn-page:hover:not(.disabled) {
    background: var(--color-primary);
    color: #000;
  }

  .btn-page.disabled {
    border-color: var(--color-border);
    color: var(--color-text-muted);
    opacity: 0.5;
    cursor: not-allowed;
  }

  .page-info {
    color: var(--color-text-muted);
    font-size: 14px;
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
    
    .pagination {
      flex-direction: column;
      gap: 15px;
    }
  }
</style>
