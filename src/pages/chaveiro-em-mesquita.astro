---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "Chaveiro em Mesquita 24h | Atendimento de Urgência e Chaves Codificadas";
const pageDescription = "Chaveiro 24 horas em Mesquita, RJ. Abertura de portas, troca de fechaduras, chaves codificadas. Atendimento residencial, comercial e automotivo rápido com chegada em 15 a 20 minutos na Baixada Fluminense.";
---

<Layout title={pageTitle} description={pageDescription}>
  <!-- JSON-LD Schema.org para SEO Local específico de Mesquita -->
  <script type="application/ld+json" slot="head" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Chaveiro Anchieta RJ",
      "image": "https://chaveiroanchietarj24h.com.br/chaveiro-em-mesquita.png",
      "@id": "https://chaveiroanchietarj24h.com.br/chaveiro-em-mesquita",
      "url": "https://chaveiroanchietarj24h.com.br/chaveiro-em-mesquita",
      "telephone": "+5521970789881",
      "priceRange": "$$",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Mesquita",
        "addressRegion": "RJ",
        "addressCountry": "BR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "-22.7811",
        "longitude": "-43.4286"
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": [
          "Monday",
          "Tuesday",
          "Wednesday",
          "Thursday",
          "Friday",
          "Saturday",
          "Sunday"
        ],
        "opens": "00:00",
        "closes": "23:59"
      },
      "areaServed": [
        {
          "@type": "AdministrativeArea",
          "name": "Mesquita, Rio de Janeiro"
        },
        {
          "@type": "AdministrativeArea",
          "name": "Anchieta, Rio de Janeiro"
        },
        {
          "@type": "AdministrativeArea",
          "name": "Nilópolis, Rio de Janeiro"
        },
        {
          "@type": "AdministrativeArea",
          "name": "Ricardo de Albuquerque, Rio de Janeiro"
        }
      ]
    }
  </script>

  <!-- FAQ Schema.org -->
  <script type="application/ld+json" slot="head" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Qual o tempo estimado para o chaveiro chegar ao bairro Cosmorama?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "O nosso tempo de resposta para o bairro Cosmorama, devido à sua proximidade com Nilópolis e Anchieta, é de apenas 10 a 15 minutos, tornando o nosso serviço um dos mais rápidos e eficazes de toda a região."
          }
        },
        {
          "@type": "Question",
          "name": "Vocês atendem chamadas de madrugada em Mesquita?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sim. O nosso plantão de atendimento de urgência funciona 24 horas por dia, 7 dias por semana. Se chegar a casa tarde da noite e perceber que perdeu a chave, basta entrar em contacto para que uma das nossas unidades móveis se desloque ao seu endereço."
          }
        },
        {
          "@type": "Question",
          "name": "Como funciona o serviço de cópia de chave codificada para carros em Mesquita?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Dispomos de equipamentos eletrónicos móveis capazes de se ligar à central do seu veículo no próprio local onde o carro se encontra. Realizamos a leitura do imobilizador e a gravação de um novo chip eletrónico na hora, poupando-lhe o custo de reboque."
          }
        },
        {
          "@type": "Question",
          "name": "É seguro contratar o vosso chaveiro residencial?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sim, a segurança é a nossa prioridade máxima. Todos os nossos técnicos passam por verificação rigorosa de antecedentes, utilizam fardamento oficial da nossa empresa e deslocam-se em viaturas devidamente identificadas, proporcionando-lhe total paz de espírito durante o atendimento."
          }
        }
      ]
    }
  </script>

  <Navbar />
  
  <main class="location-page">
    <!-- HERO SECTION -->
    <section class="loc-hero" id="hero-mesquita">
