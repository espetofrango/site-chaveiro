            </div>
            <div class="stat-divider"></div>
            <div class="stat">
              <span class="stat-number">0<small>danos</small></span>
              <span class="stat-label">À sua estrutura</span>
            </div>
          </div>
        </div>
        <div class="hero-image-wrap">
          <div class="image-glow"></div>
          <img src="/chaveiro-em-mesquita.png" alt="Chaveiro em Mesquita - Chaveiro Anchieta RJ 24 horas" class="hero-img" width="580" height="580" />
