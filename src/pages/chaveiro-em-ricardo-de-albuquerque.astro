      "telephone": "+5521970789881",
      "priceRange": "$$",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Rio de Janeiro",
        "addressRegion": "RJ",
        "addressCountry": "BR",
        "streetAddress": "Ricardo de Albuquerque"
      },
      "geo": {
        "@type": "GeoCoordinates",
